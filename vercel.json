{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/weekly-molecule",
      "schedule": "0 9 * * 1"
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth",
      "destination": "/api/ops?r=auth"
    },
    {
      "source": "/api/billing",
      "destination": "/api/ops?r=billing"
    },
    {
      "source": "/api/billing-webhook",
      "destination": "/api/ops?r=billing-webhook"
    },
    {
      "source": "/api/feed",
      "destination": "/api/ops?r=feed"
    },
    {
      "source": "/api/molecule",
      "destination": "/api/ops?r=molecule"
    },
    {
      "source": "/api/proxy",
      "destination": "/api/ops?r=proxy"
    },
    {
      "source": "/api/wardrobe",
      "destination": "/api/ops?r=wardrobe"
    },
    {
      "source": "/api/health",
      "destination": "/api/ops?r=health"
    },
    {
      "source": "/api/schema-health",
      "destination": "/api/ops?r=schema-health"
    },
    {
      "source": "/api/client-config",
      "destination": "/api/ops?r=client-config"
    },
    {
      "source": "/api/event",
      "destination": "/api/ops?r=event"
    },
    {
      "source": "/api/metrics",
      "destination": "/api/ops?r=metrics"
    },
    {
      "source": "/api/error-log",
      "destination": "/api/ops?r=error-log"
    },
    {
      "source": "/api/wardrobe-health",
      "destination": "/api/ops?r=wardrobe-health"
    },
    {
      "source": "/api/catalog-health",
      "destination": "/api/ops?r=catalog-health"
    },
    {
      "source": "/api/weekly-molecule",
      "destination": "/api/ops?r=weekly-molecule"
    },
    {
      "source": "/api/analyses",
      "destination": "/api/ops?r=analyses"
    },
    {
      "source": "/api/perfumes",
      "destination": "/api/ops?r=perfumes"
    },
    {
      "source": "/api/community-hub",
      "destination": "/api/ops?r=community-hub"
    },
    {
      "source": "/api/feed-health",
      "destination": "/api/ops?r=feed-health"
    },
    {
      "source": "/api/perfume-vote",
      "destination": "/api/labs?r=perfume-vote"
    },
    {
      "source": "/api/perfume-finder",
      "destination": "/api/labs?r=perfume-finder"
    },
    {
      "source": "/api/layering-lab",
      "destination": "/api/labs?r=layering-lab"
    },
    {
      "source": "/api/layering",
      "destination": "/api/labs?r=layering-lab"
    },
    {
      "source": "/api/layering-catalog",
      "destination": "/api/labs?r=layering-catalog"
    },
    {
      "source": "/api/notalar",
      "destination": "/api/labs?r=perfume-finder"
    },
    {
      "source": "/api/barcode-lookup",
      "destination": "/api/labs?r=barcode-lookup"
    },
    {
      "source": "/api/barcode",
      "destination": "/api/labs?r=barcode-lookup"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=(), payment=(), usb=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://generativelanguage.googleapis.com https://*.supabase.co; img-src 'self' data: https:; frame-ancestors 'none'"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    }
  ]
}
