{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist/scripts",
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", ".next"]
}
