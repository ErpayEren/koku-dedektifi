# ╔══════════════════════════════════════════════════════════════════════╗
# ║  UYARI: Bu dosyayi .env.local olarak kopyala ve doldur.            ║
# ║  .env.local asla git'e commit edilmemeli (.gitignore'da).          ║
# ║  Production'da degerleri Vercel Dashboard -> Settings ->            ║
# ║  Environment Variables bolumunden ekle.                             ║
# ╚══════════════════════════════════════════════════════════════════════╝
#
# OPS_PASSWORD icin minimum 16 karakter, rastgele uret:
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_ADVISOR_MODEL=gemini-2.5-flash-lite
ANTHROPIC_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Optional:
# GEMINI_ENABLE_WEB=true
# OPENROUTER_API_KEY=
# OPENROUTER_TEXT_MODEL=openrouter/free
# OPENROUTER_VISION_MODEL=openrouter/free
#
# Durable cache + rate limit (recommended for production/Vercel):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# or:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# In Vercel production, non-durable fallback is blocked by default.
# Set this only for temporary emergency bypass:
# ALLOW_NON_DURABLE_STORE=false
#
# Optional local override:
# API_STATE_FILE=.runtime/api-store.json
# KV_KEY_PREFIX=koku-dedektifi
#
# Optional wardrobe persistence (cross-device cloud sync):
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_URL= (alias accepted)
# SUPABASE_SERVICE_KEY= (alias accepted)
# SUPABASE_FRAGRANCES_TABLE=fragrances
# SUPABASE_MOLECULES_TABLE=molecules
# SUPABASE_ANALYSES_TABLE=analyses
# SUPABASE_WARDROBE_TABLE=scent_wardrobe
# SUPABASE_USERS_TABLE=app_users
# SUPABASE_FEED_TABLE=community_feed
# WARDROBE_REQUIRE_SUPABASE=true
# WARDROBE_ALLOW_RUNTIME_FALLBACK=false (strict modda/production'da dikkate alinmaz)
# FEED_REQUIRE_SUPABASE=true
# FEED_ALLOW_RUNTIME_FALLBACK=false (strict modda/production'da dikkate alinmaz)
#
# Optional metrics endpoint auth:
# METRICS_API_KEY=replace-with-strong-secret
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0
#
# Optional advisor RAG (vector retrieval):
# RAG_ENABLE_VECTOR=false
# RAG_EMBEDDING_MODEL=text-embedding-004
# PINECONE_API_KEY=
# PINECONE_INDEX_HOST=
# PINECONE_API_VERSION=2024-07
# SUPABASE_VECTOR_RPC=match_perfume_docs
# SUPABASE_VECTOR_TABLE=perfume_docs
#
# Optional billing skeleton:
# BILLING_PROVIDER=manual
# BILLING_PRICE_PRO=199
# BILLING_CURRENCY=TRY
# BILLING_INTERVAL=month
# BILLING_CHECKOUT_URL_PRO=
# BILLING_ALLOW_DEV_ACTIVATION=false
# BILLING_WEBHOOK_SECRET=
# BILLING_WEBHOOK_SIGNATURE_HEADER=x-billing-signature
# BILLING_WEBHOOK_STRIPE_TOLERANCE_SEC=300
# BILLING_WEBHOOK_PADDLE_TOLERANCE_SEC=300
#
# Stripe checkout (optional if BILLING_PROVIDER=stripe):
# BILLING_STRIPE_SECRET_KEY=
# BILLING_STRIPE_PRICE_ID_PRO=
# BILLING_STRIPE_SUCCESS_URL=https://koku-dedektifi.vercel.app/?billing=success
# BILLING_STRIPE_CANCEL_URL=https://koku-dedektifi.vercel.app/?billing=cancel
# BILLING_STRIPE_API_BASE=https://api.stripe.com/v1
#
# Paddle checkout (optional if BILLING_PROVIDER=paddle):
# BILLING_PADDLE_API_KEY=
# BILLING_PADDLE_PRICE_ID_PRO=
# BILLING_PADDLE_CHECKOUT_URL=https://koku-dedektifi.vercel.app
# BILLING_PADDLE_API_BASE=https://api.paddle.com
# Ops Panel Basic Auth
OPS_USER=admin
OPS_PASSWORD=  # node -e "console.log(require('crypto').randomBytes(16).toString('hex'))" ile uret
